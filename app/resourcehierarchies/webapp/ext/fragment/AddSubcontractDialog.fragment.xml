<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="vhSubcontractDialog"
        title="Select Subcontracts"
        contentWidth="55%">

        <subHeader>
            <Toolbar>

                <SearchField
                    id="inpSubcontractId"
                    placeholder="Search Subcontract ID"
                    width="25%"
                    liveChange="onSubcontractSearch" />

                <SearchField
                    id="inpSubcontractName"
                    placeholder="Search Subcontract Name"
                    width="35%"
                    liveChange="onSubcontractSearch" />

                <ToolbarSpacer />

                <Select
                    id="inpSubcontractType"
                    width="25%"
                    change="onSubcontractSearch"
                    items="{rtModel>/uniqueTypes}">

                    <core:Item
                        key="{rtModel>key}"
                        text="{rtModel>text}" />
                </Select>

            </Toolbar>
        </subHeader>

        <Table
            id="tblSubcontract"
            inset="false"
            mode="None"
            items="{rtModel>/items}">

            <columns>

                <Column width="3rem" hAlign="Center">
                    <header>
                        <CheckBox select="onSelectAllSubcontract" />
                    </header>
                </Column>

                <Column>
                    <Text text="Subcontract ID" />
                </Column>

                <Column>
                    <Text text="Subcontract Name" />
                </Column>

                <Column>
                    <Text text="Subcontract Type" />
                </Column>

            </columns>

            <items>
                <ColumnListItem>
                    <cells>

                        <CheckBox
                            selected="{rtModel>isSelected}"
                            enabled="{rtModel>isEnabled}" />

                        <Text text="{rtModel>Product}" />
                        <Text text="{rtModel>ProductDescription}" />
                        <Text text="{rtModel>ProductType}" />

                    </cells>
                </ColumnListItem>
            </items>

        </Table>

        <beginButton>
            <Button
                text="Add"
                type="Emphasized"
                press="onConfirmSubcontract" />
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press="onCancelSubcontract" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>
 