<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    core:require="{ handler: 'ns/resourcehierarchies/ext/fragment/AddNode'}">

    <Dialog id="_IDGenDialog1" title="Add Node" contentWidth="450px">
        <content>
            <VBox id="_IDGenVBox1" class="sapUiSmallMargin">

                <Label id="_IDGenLabel" text="Select Type" design="Bold" />

                <RadioButtonGroup
                    id="modeRB"
                    columns="2"
                    select="handler.onTypeChange">

                    <buttons>
                        <RadioButton id="_IDGenRadioButton" text="Node" />
                        <RadioButton id="_IDGenRadioButton1" text="Resource Type" />
                    </buttons>
                </RadioButtonGroup>

               <form:SimpleForm id="_IDGenSimpleForm" editable="true" layout="ResponsiveGridLayout" class="sapUiTinyMarginTop">

    <Label id="lblName" text="Name" required="true" />
    <Input id="inpName" />

    <Label text="Description" />
    <Input id="inpDesc" />

    <Label id="lblRT" text="Resource Type" visible="false" required="true" />

    <Input id="inpRT" visible="false" showValueHelp="true" valueHelpRequest="handler.onResourceTypeVH" />

</form:SimpleForm>

        </VBox>
        </content>
        <beginButton>
            <Button id="_IDGenButton1" text="Create" type="Emphasized" press="handler.onSubmit" />
        </beginButton>
        <endButton>
            <Button id="_IDGenButton2" text="Cancel" press="handler.onCancel" />
        </endButton>
    </Dialog>

</core:FragmentDefinition>
