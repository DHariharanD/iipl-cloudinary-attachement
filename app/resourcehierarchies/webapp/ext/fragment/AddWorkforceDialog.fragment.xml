<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="vhWorkforceDialog"
        title="Select Workforce"
        contentWidth="60%"
        draggable="true"
        resizable="true">

        <subHeader>
            <Toolbar>

                <SearchField
                    id="searchWFId"
                    placeholder="Search Assignment ID"
                    width="30%"
                    liveChange="onWorkforceSearch"/>

                <SearchField
                    id="searchWFLevel"
                    placeholder="Search Service Level"
                    width="40%"
                    liveChange="onWorkforceSearch"/>

                <ToolbarSpacer/>

            </Toolbar>
        </subHeader>

        <Table
            id="tblWorkforce"
            inset="false"
            mode="MultiSelect"
            items="{rtModel>/items}">

            <columns>
                <Column>
                    <Text text="Assignment ID"/>
                </Column>

                <Column>
                    <Text text="Service Level"/>
                </Column>
            </columns>

            <items>
                <ColumnListItem>

                    <cells>
                        <Text text="{rtModel>name}"/>
                        <Text text="{rtModel>description}"/>
                    </cells>

                </ColumnListItem>

            </items>

        </Table>

        <beginButton>
            <Button
                text="Add"
                type="Emphasized"
                press="onWorkforceConfirm"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press="onWorkforceCancel"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
