<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="vhProductDialog"
        title="Select Products"
        contentWidth="55%"
       >

        <subHeader>
            <Toolbar>

                <SearchField
                    id="inpProdId"
                    placeholder="Search Product ID"
                    width="25%"
                    liveChange="onProductSearch" />

                <SearchField
                    id="inpProdName"
                    placeholder="Search Product Name"
                    width="35%"
                    liveChange="onProductSearch" />

                <ToolbarSpacer />

                <Select
                    id="inpProdType"
                    width="25%"
                    change="onProductSearch"
                    items="{rtModel>/uniqueTypes}">

                    <core:Item
                        key="{rtModel>key}"
                        text="{rtModel>text}" />

                </Select>


            </Toolbar>
        </subHeader>

        <Table
            id="tblProduct"
            inset="false"
            mode="None"
            items="{rtModel>/items}">

            <columns>

                <Column width="3rem" hAlign="Center">
                    <header>
                        <CheckBox select="onSelectAllProduct" />
                    </header>
                </Column>

                <Column>
                    <Text text="Product ID" />
                </Column>

                <Column>
                    <Text text="Product Name" />
                </Column>

                <Column>
                    <Text text="Product Type" />
                </Column>
                <Column>
                    <Text text="UOM" />
                </Column>

            </columns>

            <items>
                <ColumnListItem>
                    <cells>

                        <CheckBox
                            selected="{rtModel>isSelected}"
                            enabled="{rtModel>isEnabled}" />

                        <Text text="{rtModel>Product}" />
                        <Text text="{rtModel>ProductDescription}" />
                        <Text text="{rtModel>ProductType}" />
                        <Text text="{rtModel>BaseUnit}" />

                    </cells>
                </ColumnListItem>
            </items>

        </Table>

        <beginButton>
            <Button
                text="Add"
                type="Emphasized"
                press="onConfirmProduct" />
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press="onCancelProduct" />
        </endButton>

    </Dialog>

</core:FragmentDefinition>