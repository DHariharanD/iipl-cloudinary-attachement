<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog id="_IDGenDialog1" title="Edit Asset Make">

        <VBox id="_IDGenVBox" class="sapUiSmallMargin">

            <Label id="_IDGenLabel" text="Asset Code"/>
            <Input id="_IDGenInput" value="{assetCode}" />

            <Label id="_IDGenLabel1" text="Asset Name"/>
            <Input id="_IDGenInput1" value="{assetName}" />

            <Label id="_IDGenLabel2" text="Description"/>
            <Input id="_IDGenInput2" value="{assetDescr}" />

            <Label id="_IDGenLabel3" text="Company Code"/>
            <Input id="_IDGenInput3" value="{companyCode}" />

        </VBox>

        <beginButton>
            <Button id="_IDGenButton" text="Save" press=".onSave"/>
        </beginButton>

        <endButton>
            <Button id="_IDGenButton1" text="Cancel" press=".onCancel"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>