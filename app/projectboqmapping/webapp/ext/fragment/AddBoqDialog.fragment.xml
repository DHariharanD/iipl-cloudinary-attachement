<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">

  <Dialog
   id="dlgAddBoq"
    title="Add BOQ"
    contentWidth="70%">

    <Table
      id="tblBoq"
      mode="MultiSelect"
      items="{rtModel>/}">
      <columns>
        <Column><Text text="Item"/></Column>
        <Column><Text text="Description"/></Column>
        <Column><Text text="UoM"/></Column>
        <Column><Text text="Qty"/></Column>
      </columns>

      <items>
        <ColumnListItem>
          <cells>
            <Text text="{rtModel>item}"/>
            <Text text="{rtModel>description}"/>
            <Text text="{rtModel>unitOfMeasurement}"/>
            <Text text="{rtModel>quantity}"/>
          </cells>
        </ColumnListItem>
      </items>
    </Table>

    <endButton>
      <Button text="Cancel" press=".onCancel"/>
    </endButton>

    <beginButton>
      <Button
        text="Add"
        type="Emphasized"
        press=".onConfirmBoq"/>
    </beginButton>

  </Dialog>
</core:FragmentDefinition>
