<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="addResourceDialog"
        title="Add Resource"
        draggable="true"
        resizable="true">

        <VBox class="sapUiSmallMargin">

            <Table
                id="resTable"
                mode="MultiSelect"
                growing="true"
                items="{/}">

                <columns>

                    <Column>
                        <Text text="Product ID"/>
                    </Column>

                    <Column>
                        <Text text="Name"/>
                    </Column>

                    <Column>
                        <Text text="UOM"/>
                    </Column>

                </columns>

                <items>
                    <ColumnListItem>

                        <cells>
                            <Text text="{productId}"/>
                            <Text text="{productName}"/>
                            <Text text="{unitofMeasure}"/>
                        </cells>

                    </ColumnListItem>
                </items>

            </Table>

        </VBox>

        <beginButton>
            <Button
                text="Add"
                type="Emphasized"
                press=".onAddResourceConfirm"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onCloseResource"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
