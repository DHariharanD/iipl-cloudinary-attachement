{
  "_version": "1.76.0",
  "sap.app": {
    "id": "ns.projectprimaveramapping",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.0",
      "toolsId": "545b2266-62ae-4e11-b210-baca78764ad8"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/ProjectPrimaveraService/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "wbsprimaveramapping-display": {
          "semanticObject": "wbsprimaveramapping",
          "action": "display",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.144.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ns.projectprimaveramapping.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ProjectPrimaveraMappingList",
          "target": "ProjectPrimaveraMappingList"
        },
        {
          "pattern": "ProjectPrimaveraMapping({key}):?query:",
          "name": "ProjectPrimaveraMappingObjectPage",
          "target": "ProjectPrimaveraMappingObjectPage"
        }
      ],
      "targets": {
        "ProjectPrimaveraMappingList": {
          "type": "Component",
          "id": "ProjectPrimaveraMappingList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/ProjectPrimaveraMapping",
              "variantManagement": "Page",
              "navigation": {
                "ProjectPrimaveraMapping": {
                  "detail": {
                    "route": "ProjectPrimaveraMappingObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "actions": {
                    "Pr1": {
                      "press": "ns.projectprimaveramapping.ext.controller.UploadPrimaveraProject.onPressUploadPrimaveraProject",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "Upload"
                    }
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "ProjectPrimaveraMappingObjectPage": {
          "type": "Component",
          "id": "ProjectPrimaveraMappingObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/ProjectPrimaveraMapping"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.cloud": {
    "public": true,
    "service": "ec_master.service"
  }
}
