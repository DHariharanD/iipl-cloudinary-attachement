<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="cbsCompanyCodeDialog"
        title="Select Company Codes"
        contentWidth="50%"
        draggable="true"
        resizable="true">

        <content>
            <VBox>

                <HBox width="100%" justifyContent="SpaceBetween" renderType="Bare">

                    <SearchField
                        id="searchCbsCompanyCode"
                        width="48%"
                        liveChange="onCompenayCodeFilter"
                        placeholder="Search Company Code" />

                    <SearchField
                        id="searchCbsCompanyCodeName"
                        width="48%"
                        liveChange="onGLFilter"
                        placeholder="Search Company Code Name" />

                </HBox>

                <Table
                    id="tblCbsCompanyCode"
                    mode="None"
                    items="{rtModel>/items}">

                    <columns>
                        <Column width="3rem" hAlign="Center">
                            <header>
                                <CheckBox select="onSelectAllCompanyCode"/>
                            </header>
                        </Column>

                        <Column>
                            <Text text="Company Code"/>
                        </Column>

                        <Column>
                            <Text text="Company Code Name"/>
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <CheckBox
                                    selected="{rtModel>isSelected}"
                                    enabled="{rtModel>isEnabled}" />
                                <Text text="{rtModel>CompanyCode}" />
                                <Text text="{rtModel>CompanyCodeName}" />
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>
            </VBox>
        </content>

        <beginButton>
            <Button text="Add" type="Emphasized" press="onConfirmCompanyCode"/>
        </beginButton>

        <endButton>
            <Button text="Cancel" press="onCancelCompanyCode"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>