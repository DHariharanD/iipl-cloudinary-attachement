<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    core:require="{ handler: 'ns/costbreakdownhierarchy/ext/fragment/AddNode' }">

    <Dialog id="cbhAddNodeDialog" title="Add Cost Breakdown Node" contentWidth="450px">
        <content>
            <VBox class="sapUiSmallMargin">

                <Label text="Select Type" design="Bold" />

                <RadioButtonGroup
                    id="cbhModeRB"
                    columns="2"
                    select="handler.onTypeChange">

                    <buttons>
                        <RadioButton text="Node" />
                    </buttons>
                </RadioButtonGroup>

                <form:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    class="sapUiTinyMarginTop">

                    <Label id="cbhLblMainField" text="Node Name" required="true" />
                    <Input id="cbhMainField" valueHelpRequest="handler.onProductVH" />

                    <Label text="Description" />
                    <Input id="cbhDesc" />

                </form:SimpleForm>

            </VBox>
        </content>

        <beginButton>
            <Button text="Create" type="Emphasized" press="handler.onSubmit" />
        </beginButton>

        <endButton>
            <Button text="Cancel" press="handler.onCancel" />
        </endButton>
    </Dialog>

</core:FragmentDefinition>
