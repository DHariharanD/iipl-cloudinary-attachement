<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="addBoqItemsDialog"
        title="Select BOQ Item"
        contentWidth="800px"
        contentHeight="400px"
        >

        <Table
            id="boqTable"
            mode="MultiSelect"
            items="{boqModel>/items}">

            <columns>
                <Column>
                    <Text text="Item"/>
                </Column>
                <Column>
                    <Text text="Description"/>
                </Column>
                <Column>
                    <Text text="UOM"/>
                </Column>
                <Column>
                    <Text text="Quantity"/>
                </Column>
            </columns>

            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{boqModel>item}"/>
                        <Text text="{boqModel>description}"/>
                        <Text text="{boqModel>unitOfMeasurement}"/>
                        <Text text="{boqModel>quantity}"/>
                    </cells>
                </ColumnListItem>
            </items>

        </Table>

        <beginButton>
            <Button text="Add" press=".onSaveBoqItem"/>
        </beginButton>

        <endButton>
            <Button text="Cancel" press=".onCancelBoqItem"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>