<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="addCbsDialog"
        title="Add CBS"
        draggable="true"
        resizable="true">

        <VBox class="sapUiSmallMargin">

            <Table
    id="cbsTable"
    mode="MultiSelect"
    growing="true"
    items="{cbsModel>/items}">

                <columns>

                    <Column>
                        <Text text="Product ID"/>
                    </Column>

                    <Column>
                        <Text text="Name"/>
                    </Column>

                    <Column>
                        <Text text="UOM"/>
                    </Column>

                </columns>

                <items>
                    <ColumnListItem>

                        <cells>
                            <Text text="{cbsModel>code}"/>
<Text text="{cbsModel>name}"/>
<Text text="{cbsModel>descr}"/>
                        </cells>

                    </ColumnListItem>
                </items>

            </Table>

        </VBox>

        <beginButton>
            <Button
                text="Add"
                type="Emphasized"
                press=".onAddCbsConfirm"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onCloseCbs"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
