<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="cbsDialog"
        title="Select CBS"
        contentWidth="60%"
        draggable="true"
        resizable="true">

        <content>

            <Table
                id="tblCbs"
                mode="MultiSelect"
                items="{cbsModel>/}">

                <columns>

                    <Column>
                        <Text text="Code"/>
                    </Column>

                    <Column>
                        <Text text="Name"/>
                    </Column>

                    <Column>
                        <Text text="Description"/>
                    </Column>

                </columns>

                <items>
                    <ColumnListItem>

                        <cells>

                            <Text text="{cbsModel>code}"/>
                            <Text text="{cbsModel>name}"/>
                            <Text text="{cbsModel>descr}"/>

                        </cells>

                    </ColumnListItem>
                </items>

            </Table>

        </content>

        <beginButton>
            <Button
                text="Select"
                type="Emphasized"
                press=".onConfirmCbs"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onCloseCbsDialog"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
