{
  "_version": "1.76.0",
  "sap.app": {
    "id": "ns.projectprimaverawbsmapping",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.0",
      "toolsId": "3c7e126f-b6ac-4402-9045-e6cfd3aef969"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/ProjectPrimaveraWBSService/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "wbs-display": {
          "semanticObject": "wbs",
          "action": "display",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "ns.projectprimaverawbsmapping.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "PrimaveraProjectsList",
          "target": "PrimaveraProjectsList"
        },
        {
          "pattern": "PrimaveraProjects({key}):?query:",
          "name": "PrimaveraProjectsObjectPage",
          "target": "PrimaveraProjectsObjectPage"
        },
        {
          "name": "PrimaveraProjects_prHierarchiesObjectPage",
          "pattern": "PrimaveraProjects({key})/prHierarchies({prHierarchiesKey}):?query:",
          "target": "PrimaveraProjects_prHierarchiesObjectPage"
        }
      ],
      "targets": {
        "PrimaveraProjectsList": {
          "type": "Component",
          "id": "PrimaveraProjectsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/PrimaveraProjects",
              "variantManagement": "Page",
              "navigation": {
                "PrimaveraProjects": {
                  "detail": {
                    "route": "PrimaveraProjectsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "actions": {
                    "up1": {
                      "press": "ns.projectprimaverawbsmapping.ext.controller.UploadWbsProject.onUploadWbsProject",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": false,
                      "text": "Upload"
                    }
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "PrimaveraProjectsObjectPage": {
          "type": "Component",
          "id": "PrimaveraProjectsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/PrimaveraProjects",
              "controlConfiguration": {
                "prHierarchies/@com.sap.vocabularies.UI.v1.LineItem#i18nPrimaveraWbsElements": {
                  "tableSettings": {
                    "type": "TreeTable",
                    "hierarchyQualifier": "PrimaveraWBS"
                  }
                }
              },
              "navigation": {
                "prHierarchies": {
                  "detail": {
                    "route": "PrimaveraProjects_prHierarchiesObjectPage"
                  }
                }
              }
            }
          }
        },
        "PrimaveraProjects_prHierarchiesObjectPage": {
          "type": "Component",
          "id": "PrimaveraProjects_prHierarchiesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/PrimaveraProjects/prHierarchies"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.cloud": {
    "public": true,
    "service": "ec_master.service"
  }
}
